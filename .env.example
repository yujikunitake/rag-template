# Database
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag_db
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag_db

# Auth
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Embedding (local default — no API cost)
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DEVICE=mps

# LLM via OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat-v3
OPENROUTER_CHEAP_MODEL=google/gemini-flash-1.5

# OpenAI (optional — alternative embedder)
OPENAI_API_KEY=your-openai-api-key
